{
  "name": "aztec-pay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf app/dist",
    "dev": "AZTEC_ENV=localnet AZTEC_NODE_URL=http://localhost:8080 API_BASE_URL= webpack serve --mode development",
    "dev:devnet": "AZTEC_ENV=devnet webpack serve --mode development",
    "build": "webpack --mode production",
    "build:devnet": "AZTEC_ENV=devnet webpack --mode production",
    "server": "tsx src/ts/server.ts",
    "server:devnet": "AZTEC_ENV=devnet tsx src/ts/server.ts",
    "start": "npm run server:devnet",
    "server:devnet:deploy": "AZTEC_ENV=devnet tsx src/ts/server-deploy.ts",
    "deploy:devnet": "AZTEC_ENV=devnet tsx src/ts/deploy-devnet.ts",
    "deploy:devnet:server": "AZTEC_ENV=devnet tsx src/ts/deploy-devnet-server.ts",
    "test": "vitest run",
    "test:bridge": "tsx src/ts/test-bridge.ts",
    "anvil": "anvil",
    "evm:build": "cd evm && forge build",
    "evm:deploy": "dotenv -- bash -c 'cd evm && forge script script/Deploy.s.sol --rpc-url $EVM_RPC_URL --broadcast --private-key $EVM_PRIVATE_KEY --ffi'",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "railway:backend": "docker build -f Dockerfile.backend -t aztec-pay-backend .",
    "railway:frontend": "docker build -f Dockerfile.frontend -t aztec-pay-frontend .",
    "railway:push:backend": "docker build -f Dockerfile.backend -t aztec-pay-backend . && railway up --service aztec-pay-backend",
    "railway:push:frontend": "docker build -f Dockerfile.frontend -t aztec-pay-frontend . && railway up --service aztec-pay-frontend"
  },
  "dependencies": {
    "@aztec/accounts": "4.0.0-devnet.2-patch.1",
    "@aztec/aztec.js": "4.0.0-devnet.2-patch.1",
    "@aztec/foundation": "4.0.0-devnet.2-patch.1",
    "@aztec/noir-contracts.js": "4.0.0-devnet.2-patch.1",
    "@aztec/pxe": "4.0.0-devnet.2-patch.1",
    "@aztec/stdlib": "4.0.0-devnet.2-patch.1",
    "@aztec/wallets": "4.0.0-devnet.2-patch.1",
    "@defi-wonderland/aztec-standards": "4.0.0-devnet.2-patch.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "viem": "^2.44.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.5.1",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "css-loader": "^6.10.0",
    "dotenv-cli": "^8.0.0",
    "dotenv-webpack": "^8.0.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "util": "^0.12.5",
    "vitest": "^3.2.4",
    "webpack": "^5.99.6",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  }
}
