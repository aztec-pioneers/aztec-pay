# Docker ignore file - prevents unnecessary files from being copied to the build context

# Dependencies
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Build outputs
dist
*.tsbuildinfo

# Environment files (should be passed via Railway variables)
.env
.env.local
.env.*.local

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Testing
coverage
.nyc_output

# Git
.git
.gitignore

# Documentation
*.md
!README.md

# Docker files (don't need to copy these into the image)
Dockerfile*
docker-compose*
.dockerignore

# Railway config (not needed in image)
railway*.toml
nixpacks.toml

# Temporary files
tmp
temp
*.tmp
