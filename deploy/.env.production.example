# Production environment configuration for aztec-pay
# Copy this file to .env on your production server and fill in the values
# NEVER commit actual private keys to git!

# ============================================
# FRONTEND CONFIGURATION (build-time)
# These are baked into the frontend at build time
# ============================================

# Aztec Node URL - where the browser connects to Aztec
# For production: use your public aztec node URL
# Default (local dev): http://localhost:8080
AZTEC_NODE_URL=https://aztec-node.aztec-pay.xyz

# API Base URL - where the browser calls the backend API
# For production: use your public API URL (e.g., https://api.aztec-pay.xyz)
# Default (empty): uses relative URLs, nginx proxies /api to backend
# Set this if frontend and backend are on different domains
API_BASE_URL=https://api.aztec-pay.xyz

# API URL - only used for webpack dev server proxy (not needed in Docker)
# Default (local dev): http://localhost:3001
API_URL=http://localhost:3001

# ============================================
# BACKEND CONFIGURATION (runtime)
# These are used by the backend server at runtime
# ============================================

# Aztec Node URL for backend (internal docker network)
BACKEND_AZTEC_NODE_URL=http://aztec:8080

# EVM Configuration - REPLACE WITH YOUR PRODUCTION PRIVATE KEY
# WARNING: Use a dedicated wallet for production with only necessary funds
EVM_PRIVATE_KEY=<YOUR_PRODUCTION_PRIVATE_KEY>

# Base Sepolia RPC URL
EVM_RPC_URL=https://sepolia.base.org

# ERC20 Token contract address on Base Sepolia
EVM_TOKEN_ADDRESS=0x8e967C9D33E2a97cca55Be55276c05EAE39c2201
